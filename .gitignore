# ── OS junk ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
.cursor/

# ── Node ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cache/
# package-lock.json is tracked (needed for npm ci in CI)

# ── Build output (generated by npm run build) ─────────────────────────────
dist/

# ── Temp / build artifacts ─────────────────────────────────────────────────
*.tmp
*.bak
logo_b64.txt
*.log

# ── Secrets / env ──────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Service Worker cache (runtime, not source) ────────────────────────────
# sw.js is intentionally tracked; only its runtime cache is excluded
sw-cache/
